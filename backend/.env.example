PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/court_booking_assistant

# Firebase Admin
# Option 1: path to a service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Option 2: use application default credentials instead
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# OpenAI settings stay on the backend only.
OPENAI_API_KEY=sk-your-backend-only-key
OPENAI_MODEL=gpt-4.1-mini
